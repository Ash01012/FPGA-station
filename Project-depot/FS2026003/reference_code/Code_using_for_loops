module compare(
   input [159:0] i_clause,
   input [159:0] i_test,
   output o_vout
   );
   wire [159:0] w_temp;
    
// CLAUSE MATCHING
assign w_temp =(~i_clause)|(i_test);
// FINAL OUTPUT
assign o_vout = &w_temp;

endmodule


module testbench;

